# --- Source scans & georeferencing ---
# PRIVATE repo: the 7 stitched sheet scans ARE committed (© ALLHS; do NOT make this repo public or
# re-host them without ALLHS permission). Everything else under source_images is large/regenerable:
# the Zoomify tile pyramids, *_crop.tif / *_modified.tif intermediates, debug crops, and the VRT.
# Ignore the whole folder, then re-include the stitched sheets + the georeferencing point files.
source_images/*
!source_images/IR30-15-1_*_Abbotts_Langley_Herts.jpg
!source_images/*.points
# .aux.xml sidecars are regenerable GDAL stats; don't track them

# Large / regenerable build artifacts (tithe.pmtiles IS committed here for the private repo)
*.tif
*.mbtiles
award.xls
*.xls
award.csv
*.csv

# Polygon GeoJSON: regenerable from extract_polygons.py when needed
data/plot_polygons.geojson

# Review/recovery working files: regenerable from confirmed.json + the scans
data/review/crops/
data/review/candidates.json
data/review/recovered.json
data/review/confirmed.backup.json

# Local secrets (wrangler dev env vars, never commit)
.dev.vars

# Transient
*.gpkg-shm
*.gpkg-wal
scratch_*
__pycache__/
